{
  "entities": {
    "User": {
      "title": "User",
      "description": "Student or Admin profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "Full name of the user" },
        "roll": { "type": "string", "description": "Student roll number" },
        "class": { "type": "string", "description": "Class/Grade level" },
        "dept": { "type": "string", "description": "Department or group" },
        "email": { "type": "string", "format": "email", "description": "User email address" },
        "photoURL": { "type": "string", "format": "uri", "description": "Profile picture URL" },
        "points": { "type": "number", "description": "Study points earned" },
        "role": { "type": "string", "enum": ["admin", "student"], "description": "User role" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Notice": {
      "title": "Notice",
      "description": "School announcement",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Notice title" },
        "description": { "type": "string", "description": "Notice content" },
        "date": { "type": "string", "format": "date-time", "description": "Publication date" },
        "postedBy": { "type": "string", "description": "Admin name who posted" }
      },
      "required": ["title", "description", "date", "postedBy"]
    },
    "Course": {
      "title": "Course",
      "description": "Course content and live links",
      "type": "object",
      "properties": {
        "class_name": { "type": "string", "description": "Target class" },
        "subject": { "type": "string", "description": "Subject name" },
        "video_url": { "type": "string", "format": "uri", "description": "Video lesson URL" },
        "meet_link": { "type": "string", "format": "uri", "description": "Live class link (Zoom/Meet)" },
        "notes_url": { "type": "string", "format": "uri", "description": "Lecture notes URL" }
      },
      "required": ["class_name", "subject"]
    },
    "Message": {
      "title": "Message",
      "description": "Chat message",
      "type": "object",
      "properties": {
        "sender_id": { "type": "string", "description": "UID of the sender" },
        "sender_name": { "type": "string", "description": "Name of the sender" },
        "message": { "type": "string", "description": "Message content" },
        "timestamp": { "type": "string", "format": "date-time", "description": "Time sent" },
        "room_id": { "type": "string", "description": "Chat room ID (e.g., class name)" }
      },
      "required": ["sender_id", "message", "timestamp", "room_id"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/notices/{noticeId}": {
      "schema": "Notice",
      "description": "School notices"
    },
    "/courses/{courseId}": {
      "schema": "Course",
      "description": "Course materials"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Chat messages"
    }
  }
}
